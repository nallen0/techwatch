# TechWatch API Keys — copy to .env and fill in your values

# FRED (free): https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=YOUR_FRED_API_KEY_HERE

# EIA (free): https://www.eia.gov/opendata/
EIA_API_KEY=YOUR_EIA_API_KEY_HERE

# Census (free, optional): https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=YOUR_CENSUS_API_KEY_HERE

# NCBI/PubMed (optional, raises rate limit): https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=YOUR_NCBI_API_KEY_HERE

# GitHub (optional, raises rate limit): https://github.com/settings/tokens
GITHUB_TOKEN=YOUR_GITHUB_TOKEN_HERE
